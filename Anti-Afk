-- Cálculo de FPS en tiempo real
local frameTimes = {}
local lastFPSUpdate = 0

RunService.RenderStepped:Connect(function()
    local currentTime = tick()
    
    -- Limpiar tiempos antiguos (>1 segundo)
    for i = #frameTimes, 1, -1 do
        if frameTimes[i] < currentTime - 1 then
            table.remove(frameTimes, i)
        end
    end
    
    table.insert(frameTimes, currentTime)
    
    if currentTime - lastFPSUpdate >= Config.FPSUpdateRate then
        FPSValueLabel.Text = tostring(#frameTimes)
        lastFPSUpdate = currentTime
    end
end)

-- Actualización del ping
task.spawn(function()
    while getgenv().AntiAFKActive do
        local success, ping = pcall(function()
            return Stats.PerformanceStats.Ping:GetValue()
        end)
        
        if success and ping then
            PingValueLabel.Text = math.floor(ping) .. " ms"
        else
            PingValueLabel.Text = "N/A"
        end
        
        task.wait(Config.UpdateInterval)
    end
end)

-- Contador de tiempo activo (uptime)
local seconds = 0
local minutes = 0
local hours = 0
getgenv().TimerRunning = true

task.spawn(function()
    while getgenv().TimerRunning do
        task.wait(1)
        if getgenv().AntiAFKActive then
            seconds += 1
            if seconds >= 60 then
                seconds = 0
                minutes += 1
            end
            if minutes >= 60 then
                minutes = 0
                hours += 1
            end
            TimerValueLabel.Text = string.format("%02d:%02d:%02d", hours, minutes, seconds)
        end
    end
end)
